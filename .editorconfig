root = true

# All files
[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

# C# files - use tabs
[*.cs]
indent_style = tab
indent_size = 4

# Project files - use spaces with size 2
[*.csproj]
indent_style = space
indent_size = 2

# Solution files
[*.sln]
indent_style = tab
